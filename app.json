{
  "expo": {
    "name": "Light-Out",
    "slug": "Light-Out",
    "version": "1.0.0",

    "web": {
      "favicon": "./assets/lightoutLogo.png"
    },

    "experiments": {
      "tsconfigPaths": true
    },

    "plugins": [],

    "orientation": "portrait",
    "icon": "./assets/lightoutLogo.png",

    "userInterfaceStyle": "dark",

    "splash": {
      "image": "./assets/lightoutLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#12122b"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/lightoutLogo.png",
        "backgroundColor": "#12122b"
      }
    }
  }
}
